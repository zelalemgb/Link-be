# Application
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key-here
VITE_SUPABASE_PROJECT_REF=your-project-ref

# Server-side scripts / Supabase CLI (never commit real values)
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_SERVICE_ROLE_KEY=service-role-key-used-in-secure-scripts
EMAIL_VERIFICATION_CODE_SECRET=replace-with-strong-random-secret
FRONTEND_URL=https://linkhc.org
CORS_ORIGINS=https://linkhc.org,https://app.linkhc.org
# ── Local AI Service (Ollama + RAG) ─────────────────────────────────────────
# Install Ollama: https://ollama.com/download
# Pull a model:   ollama pull mistral:7b-instruct
# All clinical AI runs locally — no data leaves the facility.
LOCAL_AI_SERVICE_URL=http://127.0.0.1:8000
LOCAL_AI_TIMEOUT_MS=120000
AI_SHARED_SECRET=replace-with-strong-random-secret

# CDSS
CDSS_AI_ADVISORY_ENABLED=true

# Legacy image analysis settings
AI_PUBLIC_ENABLED=false
AI_DEBUG=false
AI_IMAGE_MAX_BYTES=5000000
FINANCE_DEBUG=false
INVENTORY_DEBUG=false
AUDIT_LOG_ENABLED=true
PATIENT_DEFAULT_TENANT_ID=
PATIENT_DOCUMENTS_BUCKET=patient-health-records
PATIENT_DOCUMENT_MAX_BYTES=10000000
MONITORING_WINDOW_MS=60000
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_AUTH_FAILURE_THRESHOLD=20
ALERT_AUDIT_FAILURE_THRESHOLD=5
ALERT_WEBHOOK_URL=

# Dev/test login (non-production only)
# Set PATIENT_DEV_LOGIN_ENABLED=true AND a strong PATIENT_DEV_LOGIN_SECRET to
# enable the /api/patient-auth/dev-login bypass. Callers must pass the secret
# in the x-dev-secret header. Never set these in production.
PATIENT_DEV_LOGIN_ENABLED=false
PATIENT_DEV_LOGIN_SECRET=replace-with-strong-random-secret
PATIENT_SESSION_SECRET=replace-with-strong-random-secret
PATIENT_OTP_PEPPER=replace-with-strong-random-secret
# PATIENT_OTP_DELIVERY: 'none' | 'sms' | 'email' (never 'console')
PATIENT_OTP_DELIVERY=none

# Optional staging overrides
# VITE_SUPABASE_URL_STAGING=
# VITE_SUPABASE_ANON_KEY_STAGING=
# SUPABASE_DB_PASSWORD_STAGING=

# Analytics / misc integrations (add as needed)
# PLAUSIBLE_DOMAIN=
# SENTRY_DSN=

# ── Subscription & Licensing (FIX 26) ────────────────────────────────────────

# RSA-2048 key pair for offline license JWTs.
# Generate with:
#   openssl genrsa -out license_private.pem 2048
#   openssl rsa -in license_private.pem -pubout -out license_public.pem
# Then paste the contents (with \n for newlines) into these vars:
LICENSE_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
LICENSE_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Chapa payment gateway (Ethiopian: https://chapa.co)
CHAPA_SECRET_KEY=CHAPASECK_TEST-xxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=replace-with-chapa-webhook-secret
CHAPA_BASE_URL=https://api.chapa.co/v1

# Stripe (optional — for USD/international payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# App base URL (for payment return URLs, email links)
APP_BASE_URL=https://admin.linkhc.org

# Local AI service (link-ml-service)
LOCAL_AI_SERVICE_URL=http://localhost:8000
LOCAL_AI_TIMEOUT_MS=90000
AI_SHARED_SECRET=replace-with-strong-random-secret

# Email delivery (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@admin.linkhc.org

# SMS delivery (Africa's Talking)
AFRICAS_TALKING_API_KEY=replace-with-at-api-key
AFRICAS_TALKING_USERNAME=replace-with-at-username

# WhatsApp delivery (Twilio — optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
